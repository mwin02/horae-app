# Mobile app — Phase 3 cloud sync env vars.
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored;
# only `.env.example` is committed.
#
# All three values are safe to ship in the client bundle:
#  - Supabase URL + anon key are designed to be public; RLS gates access.
#  - The PowerSync instance URL is a public WebSocket endpoint; PowerSync
#    authenticates via the Supabase JWT.
#
# Never put the Supabase service role key here (or anywhere committed).

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_POWERSYNC_URL=

# Sentry crash reporting. Get a DSN from https://sentry.io after creating
# a React Native project. Empty value disables Sentry (safe for dev).
EXPO_PUBLIC_SENTRY_DSN=

# Recipient for in-app "Report a bug" / "Request a feature". Falls back
# to a hardcoded address in lib/feedback.ts if unset.
EXPO_PUBLIC_SUPPORT_EMAIL=
