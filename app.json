{
  "expo": {
    "name": "Horae",
    "slug": "horae",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "horae",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#D9B583"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.myozawwin.horae",
      "appleTeamId": "827722TPEU",
      "deploymentTarget": "16.1",
      "infoPlist": {
        "NSSupportsLiveActivities": true,
        "LSApplicationQueriesSchemes": [
          "mailto",
          "mailto"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.myozawwin.horae.shared",
          "group.com.myozawwin.horae.shared"
        ]
      },
      "privacyManifests": {
        "NSPrivacyTracking": false,
        "NSPrivacyTrackingDomains": [],
        "NSPrivacyCollectedDataTypes": [],
        "NSPrivacyAccessedAPITypes": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.myozawwin.horae"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "color": "#ffffff",
          "defaultChannel": "default"
        }
      ],
      "expo-sharing",
      "@bacons/apple-targets",
      [
        "@sentry/react-native/expo",
        {
          "organization": "myo-zaw-win",
          "project": "horae-ios"
        }
      ],
      "expo-mail-composer"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "bundleIdentifier": "com.myozawwin.horae.widget",
                  "targetName": "HoraeWidget",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.myozawwin.horae.shared"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "51654fbc-04ce-4c69-95fa-4342ea409057"
      }
    },
    "owner": "rediablack"
  }
}
